# Normalize line endings to LF on checkout, prevent CRLF drift on Windows.
* text=auto eol=lf

# Force LF for code files
*.php   text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf

# Binary files (no normalization)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary

# Files excluded from GitHub archive exports (release zips)
.gitignore       export-ignore
.gitattributes   export-ignore
.github/         export-ignore
.editorconfig    export-ignore
phpcs.xml.dist   export-ignore
.eslintrc        export-ignore
.stylelintrc     export-ignore
node_modules/    export-ignore
tests/           export-ignore
